<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg"
    android:gravity="center">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- StudyMate Header Illustration / Cap -->
        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_academic_cap"
            android:layout_marginBottom="24dp"
            android:contentDescription="StudyMate Logo" />

        <TextView
            android:id="@+id/txt_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="StudyMate"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:fontFamily="sans-serif-condensed-light" />

        <TextView
            android:id="@+id/txt_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Personal Academic Companion"
            android:textSize="14sp"
            android:textColor="#D1C4E9"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="48dp"
            android:letterSpacing="0.1" />

        <ProgressBar
            android:id="@+id/splash_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:indeterminateTint="#FFC107" />

    </LinearLayout>

</RelativeLayout>
