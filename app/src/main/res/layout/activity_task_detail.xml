<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_gray">

    <!-- Top AppBar Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/app_bar_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/detail_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:titleTextColor="@android:color/white"
            app:title="Study Task Details"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Details Card Container -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/app_bar_card"
        app:layout_constraintBottom_toTopOf="@id/bottom_actions_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Detail Paper Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/light_border"
                app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Title & Status Badge container -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <!-- Status pill tag -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cv_detail_status_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:cardBackgroundColor="@color/status_pending">

                            <TextView
                                android:id="@+id/tv_detail_status_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PENDING"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="5dp" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tv_detail_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="ID: #1"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />

                    </RelativeLayout>

                    <!-- Title display -->
                    <TextView
                        android:id="@+id/tv_detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="History Exam Revision on Chapters 3 &amp; 4"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="14dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="14dp" />

                    <!-- Calendar Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DUE DATE / DEADLINE"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@android:drawable/ic_menu_my_calendar"
                                android:tint="@color/text_secondary"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tv_detail_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2026-06-25 (Thursday)"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Description Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TASK DESCRIPTION"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_detail_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed eu feugiat ex, ac pretium elementum. Pellentesque sed dolor ut sem scelerisque aliquet."
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:lineSpacingMultiplier="1.25" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Actions Controls Sheet -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_actions_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Primary Actions row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Toggle status button -->
                <Button
                    android:id="@+id/btn_toggle_completeness"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="MARK AS COMPLETED"
                    android:textColor="@color/primary"
                    app:strokeColor="@color/primary"
                    app:cornerRadius="12dp" />

                <!-- Edit Button -->
                <Button
                    android:id="@+id/btn_edit_task"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="EDIT TASK"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <!-- Delete Button -->
            <Button
                android:id="@+id/btn_delete_task"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="DELETE THIS STUDY TASK"
                android:textColor="@color/status_pending"
                android:textSize="12dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
